  LevelId: Warmup
  LevelName: "\u041F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0430 \u043A
    \u0425\u0430\u0434\u0436\u0443"
  Description: "\u0418\u0437\u0443\u0447\u0438\u0442\u0435 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0425\u0430\u0434\u0436\u0430 \u0432 \u044D\u0442\u043E\u043C \u043E\u0431\u0443\u0447\u0430\u044E\u0449\u0435\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435"
  Thumbnail: {fileID: -181533402, guid: 40fd8f33f7bce4a8793a879dd836bda1, type: 3}
  Questions:
  - QuestionText: "\u041A\u0442\u043E \u043E\u0431\u044F\u0437\u0430\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0442\u044C
      \u0445\u0430\u0434\u0436?"
    Options:
    - "\u041A\u0430\u0436\u0434\u044B\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A"
    - "\u0422\u043E\u043B\u044C\u043A\u043E \u043C\u0443\u0436\u0447\u0438\u043D\u044B"
    - "\u0424\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438 \u0438 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E
      \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u0439 \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0438\u043D"
    - "\u0422\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0436\u0438\u043B\u044B\u0435"
    CorrectAnswerIndex: 2
    Explanation: "\u0425\u0430\u0434\u0436 \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u0435\u043D
      \u0434\u043B\u044F \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0438\u043D\u0430,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438
      \u0438 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D."
    GemsReward: 5
  - QuestionText: "\u0421\u043A\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437
      \u0445\u0430\u0434\u0436 \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u0435\u043D
      \u0432 \u0436\u0438\u0437\u043D\u0438?"
    Options:
    - "\u041A\u0430\u0436\u0434\u044B\u0439 \u0433\u043E\u0434"
    - "\u041E\u0434\u0438\u043D \u0440\u0430\u0437"
    - "\u0422\u0440\u0438 \u0440\u0430\u0437\u0430"
    - "\u041D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043E"
    CorrectAnswerIndex: 1
    Explanation: "\u0425\u0430\u0434\u0436 \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u0435\u043D
      \u043E\u0434\u0438\u043D \u0440\u0430\u0437 \u0432 \u0436\u0438\u0437\u043D\u0438
      \u043F\u0440\u0438 \u043D\u0430\u043B\u0438\u0447\u0438\u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438."
    GemsReward: 5
  - QuestionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u0438\u0445\u0440\u0430\u043C?"
    Options:
    - "\u041E\u0434\u0435\u0436\u0434\u0430"
    - "\u041C\u0435\u0441\u0442\u043E"
    - "\u0421\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u043F\u043E\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u044F
      \u0441 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u044F\u043C\u0438"
    - "\u041C\u043E\u043B\u0438\u0442\u0432\u0430"
    CorrectAnswerIndex: 2
    Explanation: "\u0418\u0445\u0440\u0430\u043C \u2014 \u044D\u0442\u043E \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0435
      \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435, \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0449\u0435\u0435
      \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435 \u0438 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u044F."
    GemsReward: 5
  - QuestionText: "\u041C\u043E\u0436\u043D\u043E \u043B\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u0434\u0443\u0445\u0438 \u0432 \u0438\u0445\u0440\u0430\u043C\u0435?"
    Options:
    - "\u0414\u0430"
    - "\u041D\u0435\u0442"
    - "\u0422\u043E\u043B\u044C\u043A\u043E \u043C\u0443\u0436\u0447\u0438\u043D\u0430\u043C"
    - "\u041D\u0435\u043C\u043D\u043E\u0433\u043E \u043C\u043E\u0436\u043D\u043E"
    CorrectAnswerIndex: 1
    Explanation: "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
      \u0434\u0443\u0445\u043E\u0432 \u043F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043E."
    GemsReward: 5
  - QuestionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u043C\u0438\u043A\u0430\u0442?"
    Options:
    - "\u0413\u043E\u0440\u0430"
    - "\u0413\u0440\u0430\u043D\u0438\u0446\u0430 \u0434\u043B\u044F \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C"
    - "\u0420\u044B\u043D\u043E\u043A"
    - "\u041C\u043E\u043B\u0438\u0442\u0432\u0430"
    CorrectAnswerIndex: 1
    Explanation: "\u041C\u0438\u043A\u0430\u0442 \u2014 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u0430\u044F
      \u0433\u0440\u0430\u043D\u0438\u0446\u0430 \u0434\u043B\u044F \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C."
    GemsReward: 5
  - QuestionText: "\u0427\u0442\u043E \u043D\u0443\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u043F\u0435\u0440\u0435\u0434 \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435\u043C
      \u043C\u0438\u043A\u0430\u0442\u0430?"
    Options:
    - "\u0421\u043E\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u0442\u0430\u0432\u0430\u0444"
    - "\u041D\u0430\u0434\u0435\u0442\u044C \u0438\u0445\u0440\u0430\u043C \u0438
      \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435"
    - "\u041F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C \u0432\u0435\u0441\u044C
      \u041A\u043E\u0440\u0430\u043D"
    - "\u041F\u043E\u0441\u0435\u0442\u0438\u0442\u044C \u0417\u0430\u043C\u0437\u0430\u043C"
    CorrectAnswerIndex: 1
    Explanation: "\u041F\u0435\u0440\u0435\u0434 \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435\u043C
      \u043C\u0438\u043A\u0430\u0442\u0430 \u043D\u0443\u0436\u043D\u043E \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C
      \u0432 \u0438\u0445\u0440\u0430\u043C \u0438 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435."
    GemsReward: 5
  - QuestionText: "\u041A\u043E\u0433\u0434\u0430 \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442\u0441\u044F
      \u0442\u0430\u043B\u044C\u0431\u0438\u044F?"
    Options:
    - "\u041F\u043E\u0441\u043B\u0435 \u0410\u0440\u0430\u0444\u0430\u0442\u0430"
    - "\u041F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C"
    - "\u041F\u0435\u0440\u0435\u0434 \u0441\u043D\u043E\u043C"
    - "\u041F\u043E\u0441\u043B\u0435 \u0442\u0430\u0432\u0430\u0444\u0430"
    CorrectAnswerIndex: 1
    Explanation: "\u0422\u0430\u043B\u044C\u0431\u0438\u044F \u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
      \u043F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u0438\u0445\u0440\u0430\u043C\u0430."
    GemsReward: 5
  CompletionBonusGems: 20
  PassThreshold: 60
