  LevelId: level_2_miqat
  LevelName: "Miqat - \u041C\u0435\u0441\u0442\u043E \u0418\u0445\u0440\u0430\u043C\u0430"
  Description: "\u0423\u0437\u043D\u0430\u0439\u0442\u0435 \u043E \u043C\u0435\u0441\u0442\u0430\u0445
    \u043F\u0440\u0438\u043D\u044F\u0442\u0438\u044F \u0438\u0445\u0440\u0430\u043C\u0430"
  Thumbnail: {fileID: -1184445823, guid: 40fd8f33f7bce4a8793a879dd836bda1, type: 3}
  Questions:
  - QuestionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u043C\u0438\u043A\u0430\u0442?"
    Options:
    - "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0430\u044F \u0433\u043E\u0440\u0430"
    - "\u0413\u0440\u0430\u043D\u0438\u0446\u0430 \u0434\u043B\u044F \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C"
    - "\u041C\u043E\u043B\u0438\u0442\u0432\u0430"
    - "\u0413\u043E\u0440\u043E\u0434"
    CorrectAnswerIndex: 1
    Explanation: "\u041C\u0438\u043A\u0430\u0442 \u2014 \u044D\u0442\u043E \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u0430\u044F
      \u0433\u0440\u0430\u043D\u0438\u0446\u0430, \u0433\u0434\u0435 \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A
      \u0434\u043E\u043B\u0436\u0435\u043D \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C
      \u0432 \u0438\u0445\u0440\u0430\u043C."
    GemsReward: 5
  - QuestionText: "\u041C\u043E\u0436\u043D\u043E \u043B\u0438 \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u0442\u044C
      \u043C\u0438\u043A\u0430\u0442 \u0431\u0435\u0437 \u0438\u0445\u0440\u0430\u043C\u0430?"
    Options:
    - "\u0414\u0430"
    - "\u041D\u0435\u0442"
    - "\u0422\u043E\u043B\u044C\u043A\u043E \u043D\u043E\u0447\u044C\u044E"
    - "\u0418\u043D\u043E\u0433\u0434\u0430 \u043C\u043E\u0436\u043D\u043E"
    CorrectAnswerIndex: 1
    Explanation: "\u041F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u0442\u044C \u043C\u0438\u043A\u0430\u0442
      \u0431\u0435\u0437 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C \u043D\u0435\u043B\u044C\u0437\u044F
      \u043F\u0440\u0438 \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0438 \u0445\u0430\u0434\u0436\u0430."
    GemsReward: 5
  - QuestionText: "\u0427\u0442\u043E \u043D\u0443\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u043F\u0435\u0440\u0435\u0434 \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435\u043C
      \u043C\u0438\u043A\u0430\u0442\u0430?"
    Options:
    - "\u0421\u0434\u0435\u043B\u0430\u0442\u044C \u0442\u0430\u0432\u0430\u0444"
    - "\u0421\u0434\u0435\u043B\u0430\u0442\u044C \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435
      \u0438 \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C \u0432 \u0438\u0445\u0440\u0430\u043C"
    - "\u041F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C \u041A\u043E\u0440\u0430\u043D"
    - "\u041F\u043E\u0441\u0435\u0442\u0438\u0442\u044C \u0417\u0430\u043C\u0437\u0430\u043C"
    CorrectAnswerIndex: 1
    Explanation: "\u041F\u0435\u0440\u0435\u0434 \u043C\u0438\u043A\u0430\u0442\u043E\u043C
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435 \u0438 \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C
      \u0432 \u0438\u0445\u0440\u0430\u043C."
    GemsReward: 5
  - QuestionText: "\u0427\u0442\u043E \u043D\u0430\u0434\u0435\u0432\u0430\u044E\u0442
      \u043C\u0443\u0436\u0447\u0438\u043D\u044B \u0432 \u0438\u0445\u0440\u0430\u043C\u0435?"
    Options:
    - "\u041E\u0431\u044B\u0447\u043D\u0443\u044E \u043E\u0434\u0435\u0436\u0434\u0443"
    - "\u0414\u0432\u0430 \u0431\u0435\u043B\u044B\u0445 \u043A\u0443\u0441\u043A\u0430
      \u0442\u043A\u0430\u043D\u0438"
    - "\u041A\u043E\u0441\u0442\u044E\u043C"
    - "\u041B\u044E\u0431\u0443\u044E \u0443\u0434\u043E\u0431\u043D\u0443\u044E
      \u043E\u0434\u0435\u0436\u0434\u0443"
    CorrectAnswerIndex: 1
    Explanation: "\u041C\u0443\u0436\u0447\u0438\u043D\u044B \u043D\u0430\u0434\u0435\u0432\u0430\u044E\u0442
      \u0434\u0432\u0430 \u0431\u0435\u043B\u044B\u0445 \u043A\u0443\u0441\u043A\u0430
      \u0442\u043A\u0430\u043D\u0438 \u0431\u0435\u0437 \u0448\u0432\u043E\u0432."
    GemsReward: 5
  - QuestionText: "\u0427\u0442\u043E \u0434\u0435\u043B\u0430\u044E\u0442 \u043F\u043E\u0441\u043B\u0435
      \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0438\u0445\u0440\u0430\u043C?"
    Options:
    - "\u041D\u0430\u0447\u0438\u043D\u0430\u044E\u0442 \u0442\u0430\u0432\u0430\u0444"
    - "\u041F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u044F\u0442 \u0442\u0430\u043B\u044C\u0431\u0438\u044E"
    - "\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044E\u0442\u0441\u044F \u0434\u043E\u043C\u043E\u0439"
    - "\u0421\u043D\u0438\u043C\u0430\u044E\u0442 \u043E\u0431\u0443\u0432\u044C"
    CorrectAnswerIndex: 1
    Explanation: "\u041F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A
      \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442 \u0442\u0430\u043B\u044C\u0431\u0438\u044E."
    GemsReward: 5
  - QuestionText: "\u0415\u0441\u043B\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
      \u043F\u0435\u0440\u0435\u0441\u0451\u043A \u043C\u0438\u043A\u0430\u0442 \u0431\u0435\u0437
      \u0438\u0445\u0440\u0430\u043C\u0430, \u0447\u0442\u043E \u043D\u0443\u0436\u043D\u043E
      \u0441\u0434\u0435\u043B\u0430\u0442\u044C?"
    Options:
    - "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C \u043F\u0443\u0442\u044C"
    - "\u0412\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u043A \u043C\u0438\u043A\u0430\u0442\u0443"
    - "\u0418\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C \u044D\u0442\u043E"
    - "\u041D\u0430\u0447\u0430\u0442\u044C \u0441\u0430\u0438"
    CorrectAnswerIndex: 1
    Explanation: "\u041D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
      \u043A \u043C\u0438\u043A\u0430\u0442\u0443 \u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E
      \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C \u0432 \u0438\u0445\u0440\u0430\u043C."
    GemsReward: 5
  - QuestionText: "\u041A\u043E\u0433\u0434\u0430 \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442\u0441\u044F
      \u0442\u0430\u043B\u044C\u0431\u0438\u044F?"
    Options:
    - "\u0414\u043E \u0438\u0445\u0440\u0430\u043C\u0430"
    - "\u041F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C"
    - "\u041F\u043E\u0441\u043B\u0435 \u0410\u0440\u0430\u0444\u0430\u0442\u0430"
    - "\u041F\u043E\u0441\u043B\u0435 \u0445\u0430\u0434\u0436\u0430"
    CorrectAnswerIndex: 1
    Explanation: "\u0422\u0430\u043B\u044C\u0431\u0438\u044F \u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
      \u043F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u0438\u0445\u0440\u0430\u043C\u0430."
    GemsReward: 5
  CompletionBonusGems: 20
  PassThreshold: 60
