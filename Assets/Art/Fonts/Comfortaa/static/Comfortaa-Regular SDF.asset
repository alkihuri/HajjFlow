    characterSequence: "key,ru,bs,al,tr,ar,id,en\r\n# === LEVEL DESCRIPTIONS ===,,,,,,,\r\nMIQAT_LEVEL_DESCRIPTION_KEY,\u041C\u0438\u043A\u0430\u0442
      \u2014 \u043C\u0435\u0441\u0442\u043E \u0432\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C,Miqat \u2014 mjesto ulaska u ihram,Miqat
      \u2014 vendi i hyrjes n\xEB ihram,Miqat \u2014 ihrama giri\u015F yeri,\u0627\u0644\u0645\u064A\u0642\u0627\u062A
      \u2014 \u0645\u0643\u0627\u0646 \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A
      \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Miqat \u2014 tempat masuk ihram,Mikat
      is the place where one enters ihram.\r\nWARMUP_LEVEL_DESCRIPTION_KEY,\u041F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0430
      \u043A \u0425\u0430\u0434\u0436\u0443,Priprema za Had\u017E,P\xEBrgatitja p\xEBr
      Haxh,Hacca Haz\u0131rl\u0131k,\u0627\u0644\u0627\u0633\u062A\u0639\u062F\u0627\u062F
      \u0644\u0644\u062D\u062C,Persiapan Haji,Preparing for Hajj\r\nTAWAF_LEVEL_DESCRIPTION_KEY,\u041E\u0431\u0445\u043E\u0434
      \u041A\u0430\u0430\u0431\u044B,Obilazak Kabe,Tavafi i Qabes,K\xE2be Tavaf\u0131,\u0627\u0644\u0637\u0648\u0627\u0641
      \u062D\u0648\u0644 \u0627\u0644\u0643\u0639\u0628\u0629,Tawaf Kabah,Circumambulation
      of the Kaaba\r\n,,,,,,,\r\n# === LEVEL 1 THEORY ===,,,,,,,\r\nTHEORY_L1_HAJJ_OBLIGATION_TITLE,\u041E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
      \u0445\u0430\u0434\u0436\u0430,Obaveza had\u017Ea,Detyrimi i Haxhit,Hac Farziyeti,\u0641\u0631\u0636\u064A\u0629
      \u0627\u0644\u062D\u062C,Kewajiban Haji,The Obligation of Hajj\r\nTHEORY_L1_HAJJ_OBLIGATION_TEXT,\u0425\u0430\u0434\u0436
      \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u0435\u043D \u043E\u0434\u0438\u043D
      \u0440\u0430\u0437 \u0432 \u0436\u0438\u0437\u043D\u0438 \u0434\u043B\u044F
      \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u0445 \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D.,Had\u017E
      je obavezan jednom u \u017Eivotu za sposobne muslimane.,Haxhi \xEBsht\xEB i
      detyruesh\xEBm nj\xEB her\xEB n\xEB jet\xEB p\xEBr mysliman\xEBt e aft\xEB.,Hac
      hayatta bir kez yap\u0131lmas\u0131 gereken bir farzd\u0131r.,\u0627\u0644\u062D\u062C
      \u0641\u0631\u0636 \u0645\u0631\u0629 \u0648\u0627\u062D\u062F\u0629 \u0641\u064A
      \u0627\u0644\u0639\u0645\u0631 \u0644\u0644\u0645\u0633\u0644\u0645 \u0627\u0644\u0642\u0627\u062F\u0631.,Haji
      wajib sekali seumur hidup bagi muslim yang mampu.,Hajj is obligatory once in
      a lifetime for capable Muslims.\r\nTHEORY_L1_NIYYAH_TITLE,\u041D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435
      (\u041D\u0438\u0439\u044F),Namjera (Nijjet),Q\xEBllimi (Nijeti),Niyet,\u0627\u0644\u0646\u064A\u0629,Niat,Intention
      (Niya)\r\nTHEORY_L1_NIYYAH_TEXT,\u041B\u044E\u0431\u043E\u0435 \u043F\u043E\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u0435
      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u0441 \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435\u0433\u043E
      \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u0440\u0430\u0434\u0438
      \u0410\u043B\u043B\u0430\u0445\u0430.,Svaki ibadet po\u010Dinje iskrenom namjerom
      radi Allaha.,\xC7do adhurim fillon me q\xEBllim t\xEB sinqert\xEB p\xEBr hir
      t\xEB Allahut.,Her ibadet Allah i\xE7in samimi bir niyetle ba\u015Flar.,\u0643\u0644
      \u0639\u0628\u0627\u062F\u0629 \u062A\u0628\u062F\u0623 \u0628\u0646\u064A\u0629
      \u062E\u0627\u0644\u0635\u0629 \u0644\u0644\u0647.,Setiap ibadah dimulai dengan
      niat yang ikhlas karena Allah.,Any worship begins with a sincere intention
      for the sake of Allah.\r\nTHEORY_L1_FINANCIAL_READINESS_TITLE,\u0424\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u0430\u044F
      \u0433\u043E\u0442\u043E\u0432\u043D\u043E\u0441\u0442\u044C,Finansijska spremnost,Gatishm\xEBria
      financiare,Mali Haz\u0131rl\u0131k,\u0627\u0644\u0627\u0633\u062A\u0637\u0627\u0639\u0629
      \u0627\u0644\u0645\u0627\u0644\u064A\u0629,Kesiapan Finansial,Financial readiness\r\nTHEORY_L1_FINANCIAL_READINESS_TEXT,\u041F\u0430\u043B\u043E\u043C\u043D\u0438\u043A
      \u0434\u043E\u043B\u0436\u0435\u043D \u0438\u043C\u0435\u0442\u044C \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430
      \u0431\u0435\u0437 \u0432\u0440\u0435\u0434\u0430 \u0441\u0435\u043C\u044C\u0435
      \u0438 \u0434\u043E\u043B\u0433\u0430\u043C.,Hodo\u010Dasnik mora imati sredstva
      bez \u0161tete porodici i dugovima.,Pelegrinit duhet t\xEB ket\xEB mjete pa
      d\xEBmtuar familjen dhe borxhet.,Hac\u0131 ailesine ve bor\xE7lar\u0131na zarar
      vermeden imk\xE2nlara sahip olmal\u0131d\u0131r.,\u064A\u062C\u0628 \u0623\u0646
      \u064A\u0645\u0644\u0643 \u0627\u0644\u062D\u0627\u062C \u0627\u0644\u0645\u0627\u0644
      \u062F\u0648\u0646 \u0627\u0644\u0625\u0636\u0631\u0627\u0631 \u0628\u0639\u0627\u0626\u0644\u062A\u0647
      \u0648\u062F\u064A\u0648\u0646\u0647.,Jamaah harus memiliki dana tanpa merugikan
      keluarga dan hutang.,The pilgrim must have funds that do not harm his family
      or debts.\r\nTHEORY_L1_PHYSICAL_ABILITY_TITLE,\u0424\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0430\u044F
      \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C,Fizi\u010Dka
      sposobnost,Aft\xEBsia fizike,Fiziksel Yeterlilik,\u0627\u0644\u0642\u062F\u0631\u0629
      \u0627\u0644\u0628\u062F\u0646\u064A\u0629,Kemampuan Fisik,Physical ability\r\nTHEORY_L1_PHYSICAL_ABILITY_TEXT,\u0425\u0430\u0434\u0436
      \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u0435\u043D \u043F\u0440\u0438
      \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
      \u0435\u0433\u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u0442\u044C.,Had\u017E
      je obavezan ako postoji fizi\u010Dka mogu\u0107nost za njegovo obavljanje.,Haxhi
      \xEBsht\xEB i detyruesh\xEBm kur ka mund\xEBsi fizike p\xEBr ta kryer.,Hac
      fiziksel olarak yap\u0131labilir oldu\u011Funda farzd\u0131r.,\u0627\u0644\u062D\u062C
      \u0648\u0627\u062C\u0628 \u0639\u0646\u062F \u0627\u0644\u0642\u062F\u0631\u0629
      \u0627\u0644\u0628\u062F\u0646\u064A\u0629 \u0639\u0644\u0649 \u0623\u062F\u0627\u0626\u0647.,Haji
      wajib jika mampu secara fisik untuk melaksanakannya.,Hajj is obligatory if
      one is physically able to perform it.\r\nTHEORY_L1_IHRAM_TITLE,\u0418\u0445\u0440\u0430\u043C,Ihram,Ihrami,\u0130hram,\u0627\u0644\u0625\u062D\u0631\u0627\u0645,Ihram,Ihram\r\nTHEORY_L1_IHRAM_TEXT,\u0418\u0445\u0440\u0430\u043C
      \u2014 \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
      \u0441 \u043E\u0441\u043E\u0431\u044B\u043C\u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C\u0438
      \u0438 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u044F\u043C\u0438.,Ihram
      je sveto stanje sa posebnim pravilima i ograni\u010Denjima.,Ihrami \xEBsht\xEB
      gjendje e shenjt\xEB me rregulla dhe kufizime t\xEB ve\xE7anta.,\u0130hram
      \xF6zel kurallar\u0131 ve k\u0131s\u0131tlamalar\u0131 olan kutsal bir haldir.,\u0627\u0644\u0625\u062D\u0631\u0627\u0645
      \u062D\u0627\u0644\u0629 \u0645\u0642\u062F\u0633\u0629 \u0644\u0647\u0627
      \u0642\u0648\u0627\u0639\u062F \u0648\u0642\u064A\u0648\u062F \u062E\u0627\u0635\u0629.,Ihram
      adalah keadaan suci dengan aturan dan larangan khusus.,Ihram is a sacred state
      with special rules and restrictions.\r\nTHEORY_L1_MIQAT_TITLE,\u041C\u0438\u043A\u0430\u0442,Mikat,Mikati,M\xEEk\xE2t,\u0627\u0644\u0645\u064A\u0642\u0627\u062A,Miqat,Mikat\r\nTHEORY_L1_MIQAT_TEXT,\u041C\u0438\u043A\u0430\u0442
      \u2014 \u0433\u0440\u0430\u043D\u0438\u0446\u0430 \u0433\u0434\u0435 \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A
      \u0432\u0441\u0442\u0443\u043F\u0430\u0435\u0442 \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
      \u0438\u0445\u0440\u0430\u043C\u0430.,Mikat je granica gdje hodo\u010Dasnik
      ulazi u stanje ihrama.,Mikati \xEBsht\xEB kufiri ku pelegrin\xEBt hyjn\xEB
      n\xEB gjendjen e ihramit.,M\xEEk\xE2t hac\u0131n\u0131n ihram haline girdi\u011Fi
      s\u0131n\u0131rd\u0131r.,\u0627\u0644\u0645\u064A\u0642\u0627\u062A \u0647\u0648
      \u0627\u0644\u062D\u062F \u0627\u0644\u0630\u064A \u064A\u062F\u062E\u0644
      \u0641\u064A\u0647 \u0627\u0644\u062D\u0627\u062C \u0641\u064A \u062D\u0627\u0644\u0629
      \u0627\u0644\u0625\u062D\u0631\u0627\u0645.,Miqat adalah batas di mana jamaah
      memasuki keadaan ihram.,Mikat is the boundary where the pilgrim enters the
      state of ihram.\r\nTHEORY_L1_TALBIYAH_TITLE,\u0422\u0430\u043B\u044C\u0431\u0438\u044F,Telbija,Telbija,Telbiye,\u0627\u0644\u062A\u0644\u0628\u064A\u0629,Talbiyah,Talbiya\r\nTHEORY_L1_TALBIYAH_TEXT,\u041F\u043E\u0441\u043B\u0435
      \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0438\u0445\u0440\u0430\u043C
      \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442
      \u0442\u0430\u043B\u044C\u0431\u0438\u044E.,Nakon ulaska u ihram hodo\u010Dasnik
      izgovara telbiju.,Pas hyrjes n\xEB ihram pelegrin\xEBt thon\xEB telbijen.,\u0130hrama
      girdikten sonra hac\u0131 telbiye okur.,\u0628\u0639\u062F \u0627\u0644\u062F\u062E\u0648\u0644
      \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645 \u064A\u0631\u062F\u062F
      \u0627\u0644\u062D\u0627\u062C \u0627\u0644\u062A\u0644\u0628\u064A\u0629.,Setelah
      memasuki ihram jamaah mengucapkan talbiyah.,\"After entering ihram, the pilgrim
      recites the Talbiyah.\"\r\n,,,,,,,\r\n# === LEVEL 1 QUIZ ===,,,,,,,\r\nQ1_WHO_MUST_PERFORM_HAJJ,\u041A\u0442\u043E
      \u043E\u0431\u044F\u0437\u0430\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0442\u044C
      \u0445\u0430\u0434\u0436?,Ko je obavezan obaviti had\u017E?,Kush \xEBsht\xEB
      i detyruar t\xEB kryej\xEB Haxhin?,Hac kimlere farzd\u0131r?,\u0645\u0646 \u0627\u0644\u0630\u064A
      \u064A\u062C\u0628 \u0639\u0644\u064A\u0647 \u0623\u062F\u0627\u0621 \u0627\u0644\u062D\u062C\u061F,Siapa
      yang wajib menunaikan haji?,Who is obliged to perform Hajj?\r\nQ1_OPT_EVERYONE,\u041A\u0430\u0436\u0434\u044B\u0439
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A,Svaka osoba,\xC7do person,Herkes,\u0643\u0644
      \u0634\u062E\u0635,Setiap orang,Every person\r\nQ1_OPT_ONLY_MEN,\u0422\u043E\u043B\u044C\u043A\u043E
      \u043C\u0443\u0436\u0447\u0438\u043D\u044B,Samo mu\u0161karci,Vet\xEBm burrat,Sadece
      erkekler,\u0627\u0644\u0631\u062C\u0627\u0644 \u0641\u0642\u0637,Hanya laki-laki,Men
      only\r\nQ1_OPT_ABLE_MUSLIM,\u0424\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438
      \u0438 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u0439
      \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0438\u043D,Fizi\u010Dki
      i finansijski sposoban musliman,Mysliman i aft\xEB fizikisht dhe financiarisht,Fiziksel
      ve mali a\xE7\u0131dan g\xFCc\xFC yeten M\xFCsl\xFCman,\u0627\u0644\u0645\u0633\u0644\u0645
      \u0627\u0644\u0642\u0627\u062F\u0631 \u0628\u062F\u0646\u064A\u0627\u064B \u0648\u0645\u0627\u0644\u064A\u0627\u064B,Muslim
      yang mampu secara fisik dan finansial,A physically and financially capable
      Muslim\r\nQ1_OPT_ONLY_ELDERLY,\u0422\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0436\u0438\u043B\u044B\u0435,Samo
      stariji,Vet\xEBm t\xEB moshuarit,Sadece ya\u015Fl\u0131lar,\u0643\u0628\u0627\u0631
      \u0627\u0644\u0633\u0646 \u0641\u0642\u0637,Hanya orang tua,Only the elderly\r\nQ1_EXPLANATION,\u0425\u0430\u0434\u0436
      \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u0435\u043D \u0434\u043B\u044F
      \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0438\u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438 \u0438 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E
      \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D.,Had\u017E je obavezan za
      muslimana koji je fizi\u010Dki i finansijski sposoban.,Haxhi \xEBsht\xEB i
      detyruesh\xEBm p\xEBr myslimanin q\xEB \xEBsht\xEB i aft\xEB fizikisht dhe
      financiarisht.,Hac fiziksel ve mali a\xE7\u0131dan g\xFCc\xFC yeten M\xFCsl\xFCmana
      farzd\u0131r.,\u0627\u0644\u062D\u062C \u0641\u0631\u0636 \u0639\u0644\u0649
      \u0627\u0644\u0645\u0633\u0644\u0645 \u0627\u0644\u0642\u0627\u062F\u0631 \u0628\u062F\u0646\u064A\u0627\u064B
      \u0648\u0645\u0627\u0644\u064A\u0627\u064B.,Haji wajib bagi muslim yang mampu
      secara fisik dan finansial.,Hajj is obligatory for a Muslim who is physically
      and financially capable.\r\n,,,,,,,\r\nQ2_HOW_MANY_TIMES_HAJJ_REQUIRED,\u0421\u043A\u043E\u043B\u044C\u043A\u043E
      \u0440\u0430\u0437 \u0445\u0430\u0434\u0436 \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u0435\u043D
      \u0432 \u0436\u0438\u0437\u043D\u0438?,Koliko puta je had\u017E obavezan u
      \u017Eivotu?,Sa her\xEB \xEBsht\xEB i detyruesh\xEBm Haxhi n\xEB jet\xEB?,Hayatta
      ka\xE7 kez hac farzd\u0131r?,\u0643\u0645 \u0645\u0631\u0629 \u064A\u062C\u0628
      \u0627\u0644\u062D\u062C \u0641\u064A \u0627\u0644\u0639\u0645\u0631\u061F,Berapa
      kali haji wajib dalam seumur hidup?,How many times is Hajj obligatory in life?\r\nQ2_OPT_EVERY_YEAR,\u041A\u0430\u0436\u0434\u044B\u0439
      \u0433\u043E\u0434,Svake godine,\xC7do vit,Her y\u0131l,\u0643\u0644 \u0633\u0646\u0629,Setiap
      tahun,Every year\r\nQ2_OPT_ONCE,\u041E\u0434\u0438\u043D \u0440\u0430\u0437,Jednom,Nj\xEB
      her\xEB,Bir kez,\u0645\u0631\u0629 \u0648\u0627\u062D\u062F\u0629,Sekali,Once\r\nQ2_OPT_THREE_TIMES,\u0422\u0440\u0438
      \u0440\u0430\u0437\u0430,Tri puta,Tre her\xEB,\xDC\xE7 kez,\u062B\u0644\u0627\u062B
      \u0645\u0631\u0627\u062A,Tiga kali,Three times\r\nQ2_OPT_UNLIMITED,\u041D\u0435
      \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043E,Neograni\u010Deno,Pa
      kufi,S\u0131n\u0131rs\u0131z,\u063A\u064A\u0631 \u0645\u062D\u062F\u0648\u062F,Tidak
      terbatas,Unlimited\r\nQ2_EXPLANATION,\u0425\u0430\u0434\u0436 \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u0435\u043D
      \u043E\u0434\u0438\u043D \u0440\u0430\u0437 \u0432 \u0436\u0438\u0437\u043D\u0438
      \u043F\u0440\u0438 \u043D\u0430\u043B\u0438\u0447\u0438\u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438.,Had\u017E
      je obavezan jednom u \u017Eivotu ako postoji mogu\u0107nost.,Haxhi \xEBsht\xEB
      i detyruesh\xEBm nj\xEB her\xEB n\xEB jet\xEB n\xEBse ka mund\xEBsi.,Hac imk\xE2n
      oldu\u011Funda hayatta bir kez farzd\u0131r.,\u0627\u0644\u062D\u062C \u0648\u0627\u062C\u0628
      \u0645\u0631\u0629 \u0648\u0627\u062D\u062F\u0629 \u0641\u064A \u0627\u0644\u0639\u0645\u0631
      \u0639\u0646\u062F \u0627\u0644\u0627\u0633\u062A\u0637\u0627\u0639\u0629.,Haji
      wajib sekali seumur hidup jika mampu.,Hajj is obligatory once in a lifetime
      if possible.\r\n,,,,,,,\r\nQ3_WHAT_IS_IHRAM,\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435
      \u0438\u0445\u0440\u0430\u043C?,\u0160ta je ihram?,\xC7far\xEB \xEBsht\xEB
      ihrimi?,\u0130hram nedir?,\u0645\u0627 \u0647\u0648 \u0627\u0644\u0625\u062D\u0631\u0627\u0645\u061F,Apa
      itu ihram?,What is Ihram?\r\nQ3_OPT_CLOTHING,\u041E\u0434\u0435\u0436\u0434\u0430,Odje\u0107a,Veshje,Giysi,\u0645\u0644\u0627\u0628\u0633,Pakaian,Cloth\r\nQ3_OPT_PLACE,\u041C\u0435\u0441\u0442\u043E,Mjesto,Vend,Yer,\u0645\u0643\u0627\u0646,Tempat,Place\r\nQ3_OPT_WORSHIP_STATE,\u0421\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
      \u043F\u043E\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u044F \u0441 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u044F\u043C\u0438,Stanje
      ibadeta sa ograni\u010Denjima,Gjendje adhurimi me kufizime,\u0130badet hali
      ve k\u0131s\u0131tlamalar,\u062D\u0627\u0644\u0629 \u0639\u0628\u0627\u062F\u0629
      \u0645\u0639 \u0642\u064A\u0648\u062F,Keadaan ibadah dengan larangan,State
      of worship with limitations\r\nQ3_OPT_PRAYER,\u041C\u043E\u043B\u0438\u0442\u0432\u0430,Molitva,Lutje,Namaz,\u0635\u0644\u0627\u0629,Sholat,Prayer\r\nQ3_EXPLANATION,\u0418\u0445\u0440\u0430\u043C
      \u2014 \u044D\u0442\u043E \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0435
      \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0449\u0435\u0435
      \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435 \u0438 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u044F.,Ihram
      je sveto stanje koje uklju\u010Duje namjeru i ograni\u010Denja.,Ihrami \xEBsht\xEB
      gjendje e shenjt\xEB q\xEB p\xEBrfshin q\xEBllimin dhe kufizimet.,\u0130hram
      niyet ve k\u0131s\u0131tlamalar\u0131 i\xE7eren kutsal bir haldir.,\u0627\u0644\u0625\u062D\u0631\u0627\u0645
      \u062D\u0627\u0644\u0629 \u0645\u0642\u062F\u0633\u0629 \u062A\u0634\u0645\u0644
      \u0627\u0644\u0646\u064A\u0629 \u0648\u0627\u0644\u0642\u064A\u0648\u062F.,Ihram
      adalah keadaan suci yang mencakup niat dan larangan.,Ihram is a sacred state
      that includes intention and restrictions.\r\n,,,,,,,\r\nQ4_CAN_USE_PERFUME_IN_IHRAM,\u041C\u043E\u0436\u043D\u043E
      \u043B\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u0434\u0443\u0445\u0438 \u0432 \u0438\u0445\u0440\u0430\u043C\u0435?,Mo\u017Ee
      li se koristiti parfem u ihramu?,A mund t\xEB p\xEBrdoret parfum n\xEB ihram?,\u0130hramda
      parf\xFCm kullan\u0131labilir mi?,\u0647\u0644 \u064A\u0645\u0643\u0646 \u0627\u0633\u062A\u062E\u062F\u0627\u0645
      \u0627\u0644\u0639\u0637\u0631 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645\u061F,Bolehkah
      menggunakan parfum saat ihram?,Is it permissible to use perfume in ihram?\r\nQ4_OPT_YES,\u0414\u0430,Da,Po,Evet,\u0646\u0639\u0645,Ya,Yes\r\nQ4_OPT_NO,\u041D\u0435\u0442,Ne,Jo,Hay\u0131r,\u0644\u0627,Tidak,No\r\nQ4_OPT_ONLY_MEN,\u0422\u043E\u043B\u044C\u043A\u043E
      \u043C\u0443\u0436\u0447\u0438\u043D\u0430\u043C,Samo mu\u0161karcima,Vet\xEBm
      burrave,Sadece erkeklere,\u0644\u0644\u0631\u062C\u0627\u0644 \u0641\u0642\u0637,Hanya
      laki-laki,For men only\r\nQ4_OPT_LITTLE_BIT,\u041D\u0435\u043C\u043D\u043E\u0433\u043E
      \u043C\u043E\u0436\u043D\u043E,Malo mo\u017Ee,Pak mund,Biraz olabilir,\u0642\u0644\u064A\u0644\u0627\u064B
      \u064A\u062C\u0648\u0632,Sedikit boleh,A little is possible\r\nQ4_EXPLANATION,\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
      \u0434\u0443\u0445\u043E\u0432 \u043F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043E.,Kori\u0161tenje
      parfema nakon ulaska u ihram je zabranjeno.,P\xEBrdorimi i parfumit pas hyrjes
      n\xEB ihram \xEBsht\xEB i ndaluar.,\u0130hrama girdikten sonra parf\xFCm kullanmak
      yasakt\u0131r.,\u0627\u0633\u062A\u062E\u062F\u0627\u0645 \u0627\u0644\u0639\u0637\u0631
      \u0628\u0639\u062F \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645
      \u0645\u062D\u0631\u0645.,Penggunaan parfum setelah memasuki ihram dilarang.,The
      use of perfume after entering ihram is prohibited.\r\n,,,,,,,\r\nQ5_WHAT_IS_MIQAT,\u0427\u0442\u043E
      \u0442\u0430\u043A\u043E\u0435 \u043C\u0438\u043A\u0430\u0442?,\u0160ta je
      mikat?,\xC7far\xEB \xEBsht\xEB mikati?,M\xEEk\xE2t nedir?,\u0645\u0627 \u0647\u0648
      \u0627\u0644\u0645\u064A\u0642\u0627\u062A\u061F,Apa itu miqat?,What is miqat?\r\nQ5_OPT_MOUNTAIN,\u0413\u043E\u0440\u0430,Planina,Mal,Da\u011F,\u062C\u0628\u0644,Gunung,Mountain\r\nQ5_OPT_IHRAM_BOUNDARY,\u0413\u0440\u0430\u043D\u0438\u0446\u0430
      \u0434\u043B\u044F \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C,Granica za ulazak u ihram,Kufiri p\xEBr
      t\xEB hyr\xEB n\xEB ihram,\u0130hrama giri\u015F s\u0131n\u0131r\u0131,\u062D\u062F
      \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Batas
      untuk memasuki ihram,The boundary for entering ihram\r\nQ5_OPT_MARKET,\u0420\u044B\u043D\u043E\u043A,Pijaca,Treg,Pazar,\u0633\u0648\u0642,Pasar,Market\r\nQ5_OPT_PRAYER,\u041C\u043E\u043B\u0438\u0442\u0432\u0430,Molitva,Lutje,Namaz,\u0635\u0644\u0627\u0629,Sholat,Prayer\r\nQ5_EXPLANATION,\u041C\u0438\u043A\u0430\u0442
      \u2014 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u0430\u044F
      \u0433\u0440\u0430\u043D\u0438\u0446\u0430 \u0434\u043B\u044F \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C.,Mikat je odre\u0111ena granica za ulazak
      u ihram.,Mikati \xEBsht\xEB kufiri i caktuar p\xEBr t\xEB hyr\xEB n\xEB ihram.,M\xEEk\xE2t
      ihrama giri\u015F i\xE7in belirlenen s\u0131n\u0131rd\u0131r.,\u0627\u0644\u0645\u064A\u0642\u0627\u062A
      \u0647\u0648 \u0627\u0644\u062D\u062F \u0627\u0644\u0645\u0639\u064A\u0646
      \u0644\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645.,Miqat
      adalah batas yang ditetapkan untuk memasuki ihram.,Miqat is the established
      boundary for entering ihram.\r\n,,,,,,,\r\nQ6_WHAT_TO_DO_BEFORE_MIQAT,\u0427\u0442\u043E
      \u043D\u0443\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u043F\u0435\u0440\u0435\u0434
      \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435\u043C \u043C\u0438\u043A\u0430\u0442\u0430?,\u0160ta
      treba u\u010Diniti prije prelaska mikata?,\xC7far\xEB duhet b\xEBr\xEB para
      kalimit t\xEB mikatit?,M\xEEk\xE2t\u0131 ge\xE7meden \xF6nce ne yap\u0131lmal\u0131?,\u0645\u0627\u0630\u0627
      \u064A\u062C\u0628 \u0641\u0639\u0644\u0647 \u0642\u0628\u0644 \u0639\u0628\u0648\u0631
      \u0627\u0644\u0645\u064A\u0642\u0627\u062A\u061F,Apa yang harus dilakukan sebelum
      melewati miqat?,What should you do before crossing the miqat?\r\nQ6_OPT_PERFORM_TAWAF,\u0421\u043E\u0432\u0435\u0440\u0448\u0438\u0442\u044C
      \u0442\u0430\u0432\u0430\u0444,Obaviti tavaf,Kryej tavafin,Tavaf yapmak,\u0623\u062F\u0627\u0621
      \u0627\u0644\u0637\u0648\u0627\u0641,Melakukan tawaf,Perform tawaf\r\nQ6_OPT_WEAR_IHRAM_MAKE_NIYYAH,\u041D\u0430\u0434\u0435\u0442\u044C
      \u0438\u0445\u0440\u0430\u043C \u0438 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435,Obu\u0107i ihram i u\u010Diniti
      nijjet,Vesh ihramin dhe b\xEBj nijetin,\u0130hram giymek ve niyet etmek,\u0644\u0628\u0633
      \u0627\u0644\u0625\u062D\u0631\u0627\u0645 \u0648\u0639\u0642\u062F \u0627\u0644\u0646\u064A\u0629,Mengenakan
      ihram dan berniat,Put on ihram and make the intention\r\nQ6_OPT_READ_QURAN,\u041F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C
      \u0432\u0435\u0441\u044C \u041A\u043E\u0440\u0430\u043D,Pro\u010Ditati cijeli
      Kuran,Lexo t\xEBr\xEB Kuranin,T\xFCm Kuran'\u0131 okumak,\u0642\u0631\u0627\u0621\u0629
      \u0627\u0644\u0642\u0631\u0622\u0646 \u0643\u0627\u0645\u0644\u0627\u064B,Membaca
      seluruh Al-Quran,Read the entire Quran\r\nQ6_OPT_VISIT_ZAMZAM,\u041F\u043E\u0441\u0435\u0442\u0438\u0442\u044C
      \u0417\u0430\u043C\u0437\u0430\u043C,Posjetiti Zemzem,Vizito Zemzemin,Zemzem'i
      ziyaret etmek,\u0632\u064A\u0627\u0631\u0629 \u0632\u0645\u0632\u0645,Mengunjungi
      Zamzam,Visit Zamzam\r\nQ6_EXPLANATION,\u041F\u0435\u0440\u0435\u0434 \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435\u043C
      \u043C\u0438\u043A\u0430\u0442\u0430 \u043D\u0443\u0436\u043D\u043E \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C
      \u0432 \u0438\u0445\u0440\u0430\u043C \u0438 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435.,Prije prelaska mikata
      treba u\u0107i u ihram i u\u010Diniti nijjet.,Para kalimit t\xEB mikatit duhet
      t\xEB hysh n\xEB ihram dhe t\xEB b\xEBsh nijetin.,M\xEEk\xE2t\u0131 ge\xE7meden
      \xF6nce ihrama girmek ve niyet etmek gerekir.,\u0642\u0628\u0644 \u0639\u0628\u0648\u0631
      \u0627\u0644\u0645\u064A\u0642\u0627\u062A \u064A\u062C\u0628 \u0627\u0644\u062F\u062E\u0648\u0644
      \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645 \u0648\u0639\u0642\u062F
      \u0627\u0644\u0646\u064A\u0629.,Sebelum melewati miqat harus memasuki ihram
      dan berniat.,\"Before crossing the miqat, one must enter ihram and make an
      intention.\"\r\n,,,,,,,\r\nQ7_WHEN_TALBIYAH_RECITED,\u041A\u043E\u0433\u0434\u0430
      \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442\u0441\u044F \u0442\u0430\u043B\u044C\u0431\u0438\u044F?,Kada
      se izgovara telbija?,Kur thuhet telbija?,Telbiye ne zaman okunur?,\u0645\u062A\u0649
      \u062A\u064F\u0642\u0627\u0644 \u0627\u0644\u062A\u0644\u0628\u064A\u0629\u061F,Kapan
      talbiyah diucapkan?,When is Talbiya pronounced?\r\nQ7_OPT_AFTER_ARAFAT,\u041F\u043E\u0441\u043B\u0435
      \u0410\u0440\u0430\u0444\u0430\u0442\u0430,Nakon Arafata,Pas Arafatit,Arafat'tan
      sonra,\u0628\u0639\u062F \u0639\u0631\u0641\u0629,Setelah Arafah,After Arafat\r\nQ7_OPT_AFTER_IHRAM,\u041F\u043E\u0441\u043B\u0435
      \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0438\u0445\u0440\u0430\u043C,Nakon
      ulaska u ihram,Pas hyrjes n\xEB ihram,\u0130hrama girdikten sonra,\u0628\u0639\u062F
      \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Setelah
      memasuki ihram,After entering ihram\r\nQ7_OPT_BEFORE_SLEEP,\u041F\u0435\u0440\u0435\u0434
      \u0441\u043D\u043E\u043C,Prije spavanja,Para gjumit,Uyumadan \xF6nce,\u0642\u0628\u0644
      \u0627\u0644\u0646\u0648\u0645,Sebelum tidur,Before bed\r\nQ7_OPT_AFTER_TAWAF,\u041F\u043E\u0441\u043B\u0435
      \u0442\u0430\u0432\u0430\u0444\u0430,Nakon tavafa,Pas tavafit,Tavaftan sonra,\u0628\u0639\u062F
      \u0627\u0644\u0637\u0648\u0627\u0641,Setelah tawaf,After tawaf\r\nQ7_EXPLANATION,\u0422\u0430\u043B\u044C\u0431\u0438\u044F
      \u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0441\u043B\u0435
      \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
      \u0438\u0445\u0440\u0430\u043C\u0430.,Telbija se izgovara nakon ulaska u stanje
      ihrama.,Telbija thuhet pas hyrjes n\xEB gjendjen e ihramit.,Telbiye ihram haline
      girdikten sonra okunur.,\u0627\u0644\u062A\u0644\u0628\u064A\u0629 \u062A\u064F\u0642\u0627\u0644
      \u0628\u0639\u062F \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u062D\u0627\u0644\u0629
      \u0627\u0644\u0625\u062D\u0631\u0627\u0645.,Talbiyah diucapkan setelah memasuki
      keadaan ihram.,Talbiya is recited after entering the state of ihram.\r\n,,,,,,,\r\n#
      === LEVEL 2 THEORY ===,,,,,,,\r\nTHEORY_L2_WHAT_IS_MIQAT_TITLE,\u0427\u0442\u043E
      \u0442\u0430\u043A\u043E\u0435 \u043C\u0438\u043A\u0430\u0442,\u0160ta je mikat,\xC7far\xEB
      \xEBsht\xEB mikati,M\xEEk\xE2t nedir,\u0645\u0627 \u0647\u0648 \u0627\u0644\u0645\u064A\u0642\u0627\u062A,Apa
      itu Miqat,What is miqat?\r\nTHEORY_L2_WHAT_IS_MIQAT_TEXT,\u041C\u0438\u043A\u0430\u0442
      \u2014 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u0430\u044F
      \u0433\u0440\u0430\u043D\u0438\u0446\u0430 \u0434\u043B\u044F \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C.,Mikat je odre\u0111ena granica za ulazak
      u ihram.,Mikati \xEBsht\xEB kufiri i caktuar p\xEBr t\xEB hyr\xEB n\xEB ihram.,M\xEEk\xE2t
      ihrama giri\u015F i\xE7in belirlenen s\u0131n\u0131rd\u0131r.,\u0627\u0644\u0645\u064A\u0642\u0627\u062A
      \u0647\u0648 \u0627\u0644\u062D\u062F \u0627\u0644\u0645\u0639\u064A\u0646
      \u0644\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645.,Miqat
      adalah batas yang ditetapkan untuk memasuki ihram.,Miqat is the established
      boundary for entering ihram.\r\nTHEORY_L2_CROSSING_BOUNDARY_TITLE,\u041F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435
      \u0433\u0440\u0430\u043D\u0438\u0446\u044B,Prelazak granice,Kalimi i kufirit,S\u0131n\u0131r\u0131
      Ge\xE7mek,\u0639\u0628\u0648\u0631 \u0627\u0644\u062D\u062F,Melewati Batas,Crossing
      the border\r\nTHEORY_L2_CROSSING_BOUNDARY_TEXT,\u041D\u0435\u043B\u044C\u0437\u044F
      \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u0442\u044C \u043C\u0438\u043A\u0430\u0442
      \u0431\u0435\u0437 \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u0438
      \u0438\u0445\u0440\u0430\u043C\u0430.,Nije dozvoljeno pre\u0107i mikat bez
      nijjeta i ihrama.,Nuk lejohet t\xEB kalohet mikati pa nijet dhe ihram.,M\xEEk\xE2t
      niyet ve ihram olmadan ge\xE7ilemez.,\u0644\u0627 \u064A\u062C\u0648\u0632
      \u0639\u0628\u0648\u0631 \u0627\u0644\u0645\u064A\u0642\u0627\u062A \u0628\u062F\u0648\u0646
      \u0646\u064A\u0629 \u0648\u0625\u062D\u0631\u0627\u0645.,Tidak boleh melewati
      miqat tanpa niat dan ihram.,It is not permissible to cross the miqat without
      the intention and ihram.\r\nTHEORY_L2_NIYYAH_TITLE,\u041D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435,Nijjet,Nijeti,Niyet,\u0627\u0644\u0646\u064A\u0629,Niat,Intention\r\nTHEORY_L2_NIYYAH_TEXT,\u041F\u0435\u0440\u0435\u0434
      \u043C\u0438\u043A\u0430\u0442\u043E\u043C \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A
      \u0434\u0435\u043B\u0430\u0435\u0442 \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435
      \u043D\u0430 \u0445\u0430\u0434\u0436.,Prije mikata hodo\u010Dasnik \u010Dini
      nijjet za had\u017E.,Para mikatit pelegrin\xEBt b\xEBjn\xEB nijetin p\xEBr
      haxh.,M\xEEk\xE2ttan \xF6nce hac\u0131 hac i\xE7in niyet eder.,\u0642\u0628\u0644
      \u0627\u0644\u0645\u064A\u0642\u0627\u062A \u064A\u0639\u0642\u062F \u0627\u0644\u062D\u0627\u062C
      \u0646\u064A\u0629 \u0627\u0644\u062D\u062C.,Sebelum miqat jamaah berniat untuk
      haji.,\"Before the miqat, the pilgrim makes the intention for Hajj.\"\r\nTHEORY_L2_IHRAM_CLOTHING_TITLE,\u041E\u0434\u0435\u0436\u0434\u0430
      \u0438\u0445\u0440\u0430\u043C\u0430,Odje\u0107a ihrama,Veshja e ihramit,\u0130hram
      Giysisi,\u0645\u0644\u0627\u0628\u0633 \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Pakaian
      Ihram,Ihram clothing\r\nTHEORY_L2_IHRAM_CLOTHING_TEXT,\u041C\u0443\u0436\u0447\u0438\u043D\u044B
      \u043D\u0430\u0434\u0435\u0432\u0430\u044E\u0442 \u0434\u0432\u0430 \u0431\u0435\u043B\u044B\u0445
      \u043A\u0443\u0441\u043A\u0430 \u0442\u043A\u0430\u043D\u0438 \u0431\u0435\u0437
      \u0448\u0432\u043E\u0432.,Mu\u0161karci obla\u010De dva bijela komada tkanine
      bez \u0161avova.,Burrat veshin dy cop\xEB p\xEBlhure t\xEB bardha pa qepje.,Erkekler
      diki\u015Fsiz iki beyaz par\xE7a kuma\u015F giyer.,\u064A\u0631\u062A\u062F\u064A
      \u0627\u0644\u0631\u062C\u0627\u0644 \u0642\u0637\u0639\u062A\u064A\u0646 \u0645\u0646
      \u0627\u0644\u0642\u0645\u0627\u0634 \u0627\u0644\u0623\u0628\u064A\u0636 \u0628\u062F\u0648\u0646
      \u062E\u064A\u0627\u0637\u0629.,Laki-laki mengenakan dua lembar kain putih
      tanpa jahitan.,Men wear two white pieces of seamless fabric.\r\nTHEORY_L2_WOMEN_IN_IHRAM_TITLE,\u0416\u0435\u043D\u0449\u0438\u043D\u044B
      \u0432 \u0438\u0445\u0440\u0430\u043C\u0435,\u017Dene u ihramu,Grat\xEB n\xEB
      ihram,\u0130hramda Kad\u0131nlar,\u0627\u0644\u0645\u0631\u0623\u0629 \u0641\u064A
      \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Wanita dalam Ihram,Women in ihram\r\nTHEORY_L2_WOMEN_IN_IHRAM_TEXT,\u0416\u0435\u043D\u0449\u0438\u043D\u044B
      \u043D\u0430\u0434\u0435\u0432\u0430\u044E\u0442 \u043E\u0431\u044B\u0447\u043D\u0443\u044E
      \u0441\u043A\u0440\u043E\u043C\u043D\u0443\u044E \u043E\u0434\u0435\u0436\u0434\u0443
      \u0431\u0435\u0437 \u0443\u043A\u0440\u0430\u0448\u0435\u043D\u0438\u0439.,\u017Dene
      obla\u010De obi\u010Dnu skromnu odje\u0107u bez ukrasa.,Grat\xEB veshin rroba
      t\xEB thjeshta modeste pa zbukurime.,Kad\u0131nlar s\xFCss\xFCz sade k\u0131yafetler
      giyer.,\u062A\u0631\u062A\u062F\u064A \u0627\u0644\u0646\u0633\u0627\u0621
      \u0645\u0644\u0627\u0628\u0633 \u0639\u0627\u062F\u064A\u0629 \u0645\u062D\u062A\u0634\u0645\u0629
      \u0628\u062F\u0648\u0646 \u0632\u064A\u0646\u0629.,Wanita mengenakan pakaian
      biasa yang sopan tanpa perhiasan.,\"Women wear simple, modest clothing without
      jewelry.\"\r\nTHEORY_L2_TALBIYAH_TITLE,\u0422\u0430\u043B\u044C\u0431\u0438\u044F,Telbija,Telbija,Telbiye,\u0627\u0644\u062A\u0644\u0628\u064A\u0629,Talbiyah,Talbiya\r\nTHEORY_L2_TALBIYAH_TEXT,\u041F\u043E\u0441\u043B\u0435
      \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0438\u0445\u0440\u0430\u043C
      \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442\u0441\u044F \u0442\u0430\u043B\u044C\u0431\u0438\u044F.,Nakon
      ulaska u ihram izgovara se telbija.,Pas hyrjes n\xEB ihram thuhet telbija.,\u0130hrama
      girdikten sonra telbiye okunur.,\u0628\u0639\u062F \u0627\u0644\u062F\u062E\u0648\u0644
      \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645 \u062A\u064F\u0642\u0627\u0644
      \u0627\u0644\u062A\u0644\u0628\u064A\u0629.,Setelah memasuki ihram diucapkan
      talbiyah.,\"After entering ihram, Talbiya is recited.\"\r\nTHEORY_L2_CROSSING_ERROR_TITLE,\u041E\u0448\u0438\u0431\u043A\u0430
      \u043F\u0440\u0438 \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0438,Gre\u0161ka
      pri prelasku,Gabimi gjat\xEB kalimit,Ge\xE7i\u015F Hatas\u0131,\u062E\u0637\u0623
      \u0639\u0646\u062F \u0627\u0644\u0639\u0628\u0648\u0631,Kesalahan saat Melewati,Error
      when crossing\r\nTHEORY_L2_CROSSING_ERROR_TEXT,\u0415\u0441\u043B\u0438 \u043C\u0438\u043A\u0430\u0442
      \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0451\u043D \u0431\u0435\u0437 \u0438\u0445\u0440\u0430\u043C\u0430
      \u043D\u0443\u0436\u043D\u043E \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F.,Ako
      je mikat pre\u0111en bez ihrama treba se vratiti.,N\xEBse mikati \xEBsht\xEB
      kaluar pa ihram duhet t\xEB ktheheni.,M\xEEk\xE2t ihrams\u0131z ge\xE7ildiyse
      geri d\xF6n\xFClmelidir.,\u0625\u0630\u0627 \u0639\u064F\u0628\u0631 \u0627\u0644\u0645\u064A\u0642\u0627\u062A
      \u0628\u062F\u0648\u0646 \u0625\u062D\u0631\u0627\u0645 \u064A\u062C\u0628
      \u0627\u0644\u0631\u062C\u0648\u0639.,Jika miqat dilewati tanpa ihram harus
      kembali.,\"If the miqat is crossed without ihram, one must return.\"\r\n,,,,,,,\r\n#
      === LEVEL 2 QUIZ ===,,,,,,,\r\nQ_L2_WHAT_IS_MIQAT,\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435
      \u043C\u0438\u043A\u0430\u0442?,\u0160ta je mikat?,\xC7far\xEB \xEBsht\xEB
      mikati?,M\xEEk\xE2t nedir?,\u0645\u0627 \u0647\u0648 \u0627\u0644\u0645\u064A\u0642\u0627\u062A\u061F,Apa
      itu miqat?,What is miqat?\r\nQ_L2_OPT_SACRED_MOUNTAIN,\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0430\u044F
      \u0433\u043E\u0440\u0430,Sveta planina,Mal i shenjt\xEB,Kutsal da\u011F,\u062C\u0628\u0644
      \u0645\u0642\u062F\u0633,Gunung suci,Sacred Mountain\r\nQ_L2_OPT_IHRAM_BOUNDARY,\u0413\u0440\u0430\u043D\u0438\u0446\u0430
      \u0434\u043B\u044F \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C,Granica za ulazak u ihram,Kufiri p\xEBr
      t\xEB hyr\xEB n\xEB ihram,\u0130hrama giri\u015F s\u0131n\u0131r\u0131,\u062D\u062F
      \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Batas
      untuk memasuki ihram,The boundary for entering ihram\r\nQ_L2_OPT_PRAYER,\u041C\u043E\u043B\u0438\u0442\u0432\u0430,Molitva,Lutje,Namaz,\u0635\u0644\u0627\u0629,Sholat,Prayer\r\nQ_L2_OPT_CITY,\u0413\u043E\u0440\u043E\u0434,Grad,Qytet,\u015Eehir,\u0645\u062F\u064A\u0646\u0629,Kota,City\r\nQ_L2_MIQAT_EXPLANATION,\u041C\u0438\u043A\u0430\u0442
      \u2014 \u044D\u0442\u043E \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u0430\u044F
      \u0433\u0440\u0430\u043D\u0438\u0446\u0430 \u0433\u0434\u0435 \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A
      \u0434\u043E\u043B\u0436\u0435\u043D \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C
      \u0432 \u0438\u0445\u0440\u0430\u043C.,Mikat je odre\u0111ena granica gdje
      hodo\u010Dasnik mora u\u0107i u ihram.,Mikati \xEBsht\xEB kufiri i caktuar
      ku pelegrin\xEBt duhet t\xEB hyjn\xEB n\xEB ihram.,M\xEEk\xE2t hac\u0131n\u0131n
      ihrama girmesi gereken belirlenen s\u0131n\u0131rd\u0131r.,\u0627\u0644\u0645\u064A\u0642\u0627\u062A
      \u0647\u0648 \u0627\u0644\u062D\u062F \u0627\u0644\u0645\u0639\u064A\u0646
      \u062D\u064A\u062B \u064A\u062C\u0628 \u0639\u0644\u0649 \u0627\u0644\u062D\u0627\u062C
      \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645.,Miqat
      adalah batas yang ditetapkan di mana jamaah harus memasuki ihram.,Miqat is
      the designated boundary where the pilgrim must enter ihram.\r\n,,,,,,,\r\nQ_L2_CAN_CROSS_MIQAT_WITHOUT_IHRAM,\u041C\u043E\u0436\u043D\u043E
      \u043B\u0438 \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u0442\u044C \u043C\u0438\u043A\u0430\u0442
      \u0431\u0435\u0437 \u0438\u0445\u0440\u0430\u043C\u0430?,Mo\u017Ee li se pre\u0107i
      mikat bez ihrama?,A mund t\xEB kalohet mikati pa ihram?,M\xEEk\xE2t ihrams\u0131z
      ge\xE7ilebilir mi?,\u0647\u0644 \u064A\u0645\u0643\u0646 \u0639\u0628\u0648\u0631
      \u0627\u0644\u0645\u064A\u0642\u0627\u062A \u0628\u062F\u0648\u0646 \u0625\u062D\u0631\u0627\u0645\u061F,Bolehkah
      melewati miqat tanpa ihram?,Is it permissible to cross the miqat without ihram?\r\nQ_L2_OPT_YES,\u0414\u0430,Da,Po,Evet,\u0646\u0639\u0645,Ya,Yes\r\nQ_L2_OPT_NO,\u041D\u0435\u0442,Ne,Jo,Hay\u0131r,\u0644\u0627,Tidak,No\r\nQ_L2_OPT_ONLY_AT_NIGHT,\u0422\u043E\u043B\u044C\u043A\u043E
      \u043D\u043E\u0447\u044C\u044E,Samo no\u0107u,Vet\xEBm nat\xEBn,Sadece gece,\u0641\u0642\u0637
      \u0644\u064A\u0644\u0627\u064B,Hanya malam hari,Only at night\r\nQ_L2_OPT_SOMETIMES,\u0418\u043D\u043E\u0433\u0434\u0430
      \u043C\u043E\u0436\u043D\u043E,Ponekad mo\u017Ee,Ndonj\xEBher\xEB mund,Bazen
      olabilir,\u0623\u062D\u064A\u0627\u0646\u0627\u064B \u064A\u062C\u0648\u0632,Kadang
      boleh,Sometimes it is possible\r\nQ_L2_CROSS_MIQAT_EXPLANATION,\u041F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u0442\u044C
      \u043C\u0438\u043A\u0430\u0442 \u0431\u0435\u0437 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C \u043D\u0435\u043B\u044C\u0437\u044F
      \u043F\u0440\u0438 \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0438 \u0445\u0430\u0434\u0436\u0430.,Pre\u0107i
      mikat bez ulaska u ihram nije dozvoljeno pri namjeri had\u017Ea.,Kalimi i mikatit
      pa hyr\xEB n\xEB ihram nuk lejohet kur ke nijet p\xEBr haxh.,Hac niyetiyle
      m\xEEk\xE2t\u0131 ihrams\u0131z ge\xE7mek caiz de\u011Fildir.,\u0644\u0627
      \u064A\u062C\u0648\u0632 \u0639\u0628\u0648\u0631 \u0627\u0644\u0645\u064A\u0642\u0627\u062A
      \u0628\u062F\u0648\u0646 \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A
      \u0627\u0644\u0625\u062D\u0631\u0627\u0645 \u0639\u0646\u062F \u0646\u064A\u0629
      \u0627\u0644\u062D\u062C.,Tidak boleh melewati miqat tanpa memasuki ihram jika
      berniat haji.,It is not permissible to cross the miqat without entering ihram
      if one intends to perform Hajj.\r\n,,,,,,,\r\nQ_L2_WHAT_TO_DO_BEFORE_MIQAT,\u0427\u0442\u043E
      \u043D\u0443\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u043F\u0435\u0440\u0435\u0434
      \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435\u043C \u043C\u0438\u043A\u0430\u0442\u0430?,\u0160ta
      treba u\u010Diniti prije prelaska mikata?,\xC7far\xEB duhet b\xEBr\xEB para
      kalimit t\xEB mikatit?,M\xEEk\xE2t\u0131 ge\xE7meden \xF6nce ne yap\u0131lmal\u0131?,\u0645\u0627\u0630\u0627
      \u064A\u062C\u0628 \u0641\u0639\u0644\u0647 \u0642\u0628\u0644 \u0639\u0628\u0648\u0631
      \u0627\u0644\u0645\u064A\u0642\u0627\u062A\u061F,Apa yang harus dilakukan sebelum
      melewati miqat?,What should you do before crossing the miqat?\r\nQ_L2_OPT_PERFORM_TAWAF,\u0421\u0434\u0435\u043B\u0430\u0442\u044C
      \u0442\u0430\u0432\u0430\u0444,Obaviti tavaf,B\xEBj tavafin,Tavaf yapmak,\u0623\u062F\u0627\u0621
      \u0627\u0644\u0637\u0648\u0627\u0641,Melakukan tawaf,Make tawaf\r\nQ_L2_OPT_MAKE_NIYYAH_ENTER_IHRAM,\u0421\u0434\u0435\u043B\u0430\u0442\u044C
      \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435 \u0438 \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C
      \u0432 \u0438\u0445\u0440\u0430\u043C,U\u010Diniti nijjet i u\u0107i u ihram,B\xEBj
      nijetin dhe hyj n\xEB ihram,Niyet edip ihrama girmek,\u0639\u0642\u062F \u0627\u0644\u0646\u064A\u0629
      \u0648\u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Berniat
      dan memasuki ihram,Make the intention and enter ihram\r\nQ_L2_OPT_READ_QURAN,\u041F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C
      \u041A\u043E\u0440\u0430\u043D,Pro\u010Ditati Kuran,Lexo Kuranin,Kuran okumak,\u0642\u0631\u0627\u0621\u0629
      \u0627\u0644\u0642\u0631\u0622\u0646,Membaca Al-Quran,Read the Quran\r\nQ_L2_OPT_VISIT_ZAMZAM,\u041F\u043E\u0441\u0435\u0442\u0438\u0442\u044C
      \u0417\u0430\u043C\u0437\u0430\u043C,Posjetiti Zemzem,Vizito Zemzemin,Zemzem'i
      ziyaret etmek,\u0632\u064A\u0627\u0631\u0629 \u0632\u0645\u0632\u0645,Mengunjungi
      Zamzam,Visit Zamzam\r\nQ_L2_BEFORE_MIQAT_EXPLANATION,\u041F\u0435\u0440\u0435\u0434
      \u043C\u0438\u043A\u0430\u0442\u043E\u043C \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
      \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435
      \u0438 \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C \u0432 \u0438\u0445\u0440\u0430\u043C.,Prije
      mikata potrebno je u\u010Diniti nijjet i u\u0107i u ihram.,Para mikatit duhet
      t\xEB b\xEBsh nijetin dhe t\xEB hysh n\xEB ihram.,M\xEEk\xE2ttan \xF6nce niyet
      edip ihrama girmek gerekir.,\u0642\u0628\u0644 \u0627\u0644\u0645\u064A\u0642\u0627\u062A
      \u064A\u062C\u0628 \u0639\u0642\u062F \u0627\u0644\u0646\u064A\u0629 \u0648\u0627\u0644\u062F\u062E\u0648\u0644
      \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645.,Sebelum miqat harus
      berniat dan memasuki ihram.,\"Before the miqat, one must make the intention
      and enter ihram.\"\r\n,,,,,,,\r\nQ_L2_WHAT_MEN_WEAR_IN_IHRAM,\u0427\u0442\u043E
      \u043D\u0430\u0434\u0435\u0432\u0430\u044E\u0442 \u043C\u0443\u0436\u0447\u0438\u043D\u044B
      \u0432 \u0438\u0445\u0440\u0430\u043C\u0435?,\u0160ta obla\u010De mu\u0161karci
      u ihramu?,\xC7far\xEB veshin burrat n\xEB ihram?,Erkekler ihramda ne giyer?,\u0645\u0627\u0630\u0627
      \u064A\u0631\u062A\u062F\u064A \u0627\u0644\u0631\u062C\u0627\u0644 \u0641\u064A
      \u0627\u0644\u0625\u062D\u0631\u0627\u0645\u061F,Apa yang dipakai pria saat
      ihram?,What do men wear in ihram?\r\nQ_L2_OPT_REGULAR_CLOTHES,\u041E\u0431\u044B\u0447\u043D\u0443\u044E
      \u043E\u0434\u0435\u0436\u0434\u0443,Obi\u010Dnu odje\u0107u,Rroba t\xEB zakonshme,Normal
      k\u0131yafet,\u0645\u0644\u0627\u0628\u0633 \u0639\u0627\u062F\u064A\u0629,Pakaian
      biasa,Regular clothes\r\nQ_L2_OPT_TWO_WHITE_CLOTHS,\u0414\u0432\u0430 \u0431\u0435\u043B\u044B\u0445
      \u043A\u0443\u0441\u043A\u0430 \u0442\u043A\u0430\u043D\u0438,Dva bijela komada
      tkanine,Dy cop\xEB p\xEBlhure t\xEB bardh\xEB,\u0130ki beyaz par\xE7a kuma\u015F,\u0642\u0637\u0639\u062A\u064A\u0646
      \u0645\u0646 \u0627\u0644\u0642\u0645\u0627\u0634 \u0627\u0644\u0623\u0628\u064A\u0636,Dua
      lembar kain putih,Two white pieces of fabric\r\nQ_L2_OPT_SUIT,\u041A\u043E\u0441\u0442\u044E\u043C,Odijelo,Kostum,Tak\u0131m
      elbise,\u0628\u062F\u0644\u0629,Jas,Costume\r\nQ_L2_OPT_ANY_COMFORTABLE,\u041B\u044E\u0431\u0443\u044E
      \u0443\u0434\u043E\u0431\u043D\u0443\u044E \u043E\u0434\u0435\u0436\u0434\u0443,Bilo
      koju udobnu odje\u0107u,\xC7do veshje t\xEB rehatshme,Herhangi rahat bir k\u0131yafet,\u0623\u064A
      \u0645\u0644\u0627\u0628\u0633 \u0645\u0631\u064A\u062D\u0629,Pakaian nyaman
      apa saja,Any comfortable clothes\r\nQ_L2_MEN_IHRAM_EXPLANATION,\u041C\u0443\u0436\u0447\u0438\u043D\u044B
      \u043D\u0430\u0434\u0435\u0432\u0430\u044E\u0442 \u0434\u0432\u0430 \u0431\u0435\u043B\u044B\u0445
      \u043A\u0443\u0441\u043A\u0430 \u0442\u043A\u0430\u043D\u0438 \u0431\u0435\u0437
      \u0448\u0432\u043E\u0432.,Mu\u0161karci obla\u010De dva bijela komada tkanine
      bez \u0161avova.,Burrat veshin dy cop\xEB p\xEBlhure t\xEB bardha pa qepje.,Erkekler
      diki\u015Fsiz iki beyaz par\xE7a kuma\u015F giyer.,\u064A\u0631\u062A\u062F\u064A
      \u0627\u0644\u0631\u062C\u0627\u0644 \u0642\u0637\u0639\u062A\u064A\u0646 \u0645\u0646
      \u0627\u0644\u0642\u0645\u0627\u0634 \u0627\u0644\u0623\u0628\u064A\u0636 \u0628\u062F\u0648\u0646
      \u062E\u064A\u0627\u0637\u0629.,Laki-laki mengenakan dua lembar kain putih
      tanpa jahitan.,Men wear two white pieces of seamless fabric.\r\n,,,,,,,\r\nQ_L2_WHAT_AFTER_ENTERING_IHRAM,\u0427\u0442\u043E
      \u0434\u0435\u043B\u0430\u044E\u0442 \u043F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0438\u0445\u0440\u0430\u043C?,\u0160ta se radi nakon ulaska u ihram?,\xC7far\xEB
      b\xEBhet pas hyrjes n\xEB ihram?,\u0130hrama girdikten sonra ne yap\u0131l\u0131r?,\u0645\u0627\u0630\u0627
      \u064A\u064F\u0641\u0639\u0644 \u0628\u0639\u062F \u0627\u0644\u062F\u062E\u0648\u0644
      \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645\u061F,Apa yang dilakukan
      setelah memasuki ihram?,What do you do after entering ihram?\r\nQ_L2_OPT_START_TAWAF,\u041D\u0430\u0447\u0438\u043D\u0430\u044E\u0442
      \u0442\u0430\u0432\u0430\u0444,Zapo\u010Dinju tavaf,Fillojn\xEB tavafin,Tavafa
      ba\u015Flan\u0131r,\u0627\u0644\u0628\u062F\u0621 \u0628\u0627\u0644\u0637\u0648\u0627\u0641,Memulai
      tawaf,They begin tawaf\r\nQ_L2_OPT_RECITE_TALBIYAH,\u041F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u044F\u0442
      \u0442\u0430\u043B\u044C\u0431\u0438\u044E,Izgovaraju telbiju,Thon\xEB telbija,Telbiye
      okunur,\u062A\u0631\u062F\u064A\u062F \u0627\u0644\u062A\u0644\u0628\u064A\u0629,Mengucapkan
      talbiyah,They recite the Talbiya\r\nQ_L2_OPT_RETURN_HOME,\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044E\u0442\u0441\u044F
      \u0434\u043E\u043C\u043E\u0439,Vra\u0107aju se ku\u0107i,Kthehen n\xEB sht\xEBpi,Eve
      d\xF6n\xFCl\xFCr,\u0627\u0644\u0639\u0648\u062F\u0629 \u0644\u0644\u0628\u064A\u062A,Pulang
      ke rumah,Returning home\r\nQ_L2_OPT_REMOVE_SHOES,\u0421\u043D\u0438\u043C\u0430\u044E\u0442
      \u043E\u0431\u0443\u0432\u044C,Skidaju obu\u0107u,Heqin k\xEBpuc\xEBt,Ayakkab\u0131lar
      \xE7\u0131kar\u0131l\u0131r,\u062E\u0644\u0639 \u0627\u0644\u0623\u062D\u0630\u064A\u0629,Melepas
      sepatu,They take off their shoes\r\nQ_L2_AFTER_IHRAM_EXPLANATION,\u041F\u043E\u0441\u043B\u0435
      \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0438\u0445\u0440\u0430\u043C
      \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442
      \u0442\u0430\u043B\u044C\u0431\u0438\u044E.,Nakon ulaska u ihram hodo\u010Dasnik
      izgovara telbiju.,Pas hyrjes n\xEB ihram pelegrin\xEBt thon\xEB telbija.,\u0130hrama
      girdikten sonra hac\u0131 telbiye okur.,\u0628\u0639\u062F \u0627\u0644\u062F\u062E\u0648\u0644
      \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645 \u064A\u0631\u062F\u062F
      \u0627\u0644\u062D\u0627\u062C \u0627\u0644\u062A\u0644\u0628\u064A\u0629.,Setelah
      memasuki ihram jamaah mengucapkan talbiyah.,\"After entering ihram, the pilgrim
      recites the Talbiyah.\"\r\n,,,,,,,#VALUE!\r\nQ_L2_IF_CROSSED_MIQAT_WITHOUT_IHRAM,\u0415\u0441\u043B\u0438
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u043F\u0435\u0440\u0435\u0441\u0451\u043A
      \u043C\u0438\u043A\u0430\u0442 \u0431\u0435\u0437 \u0438\u0445\u0440\u0430\u043C\u0430
      \u0447\u0442\u043E \u043D\u0443\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C?,Ako
      je osoba pre\u0161la mikat bez ihrama \u0161ta treba u\u010Diniti?,N\xEBse
      personi ka kaluar mikatin pa ihram \xE7far\xEB duhet b\xEBr\xEB?,Ki\u015Fi
      m\xEEk\xE2t\u0131 ihrams\u0131z ge\xE7tiyse ne yapmal\u0131?,\u0625\u0630\u0627
      \u0639\u0628\u0631 \u0627\u0644\u0634\u062E\u0635 \u0627\u0644\u0645\u064A\u0642\u0627\u062A
      \u0628\u062F\u0648\u0646 \u0625\u062D\u0631\u0627\u0645 \u0645\u0627\u0630\u0627
      \u064A\u062C\u0628 \u0623\u0646 \u064A\u0641\u0639\u0644\u061F,Jika seseorang
      melewati miqat tanpa ihram apa yang harus dilakukan?,\"If a person crosses
      the miqat without ihram, what should he do?\"\r\nQ_L2_OPT_CONTINUE_PATH,\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C
      \u043F\u0443\u0442\u044C,Nastaviti put,Vazhdoni rrug\xEBn,Yola devam etmek,\u0627\u0633\u062A\u0645\u0631
      \u0641\u064A \u0627\u0644\u0637\u0631\u064A\u0642,Melanjutkan perjalanan,Continue
      on your way\r\nQ_L2_OPT_RETURN_TO_MIQAT,\u0412\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
      \u043A \u043C\u0438\u043A\u0430\u0442\u0443,Vratiti se na mikat,Kthehu te mikati,M\xEEk\xE2ta
      geri d\xF6nmek,\u0627\u0644\u0639\u0648\u062F\u0629 \u0625\u0644\u0649 \u0627\u0644\u0645\u064A\u0642\u0627\u062A,Kembali
      ke miqat,Return to miqat\r\nQ_L2_OPT_IGNORE,\u0418\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u044D\u0442\u043E,Ignorisati to,Injoro k\xEBt\xEB,Bunu g\xF6rmezden gelmek,\u062A\u062C\u0627\u0647\u0644
      \u0630\u0644\u0643,Mengabaikannya,Ignore this\r\nQ_L2_OPT_START_SAI,\u041D\u0430\u0447\u0430\u0442\u044C
      \u0441\u0430\u0438,Zapo\u010Deti sai,Fillo sa'in,Sa'ye ba\u015Flamak,\u0627\u0644\u0628\u062F\u0621
      \u0628\u0627\u0644\u0633\u0639\u064A,Memulai sa'i,Start sai\r\nQ_L2_CROSSED_WITHOUT_IHRAM_EXPLANATION,\u041D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
      \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u043A \u043C\u0438\u043A\u0430\u0442\u0443
      \u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u044C
      \u0432 \u0438\u0445\u0440\u0430\u043C.,Potrebno je vratiti se na mikat i pravilno
      u\u0107i u ihram.,Duhet t\xEB ktheheni te mikati dhe t\xEB hyni si\xE7 duhet
      n\xEB ihram.,M\xEEk\xE2ta geri d\xF6n\xFCp do\u011Fru \u015Fekilde ihrama girmek
      gerekir.,\u064A\u062C\u0628 \u0627\u0644\u0639\u0648\u062F\u0629 \u0625\u0644\u0649
      \u0627\u0644\u0645\u064A\u0642\u0627\u062A \u0648\u0627\u0644\u062F\u062E\u0648\u0644
      \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645 \u0628\u0634\u0643\u0644
      \u0635\u062D\u064A\u062D.,Harus kembali ke miqat dan memasuki ihram dengan
      benar.,It is necessary to return to the miqat and enter ihram correctly.\r\n,,,,,,,\r\nQ_L2_WHEN_TALBIYAH_RECITED,\u041A\u043E\u0433\u0434\u0430
      \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442\u0441\u044F \u0442\u0430\u043B\u044C\u0431\u0438\u044F?,Kada
      se izgovara telbija?,Kur thuhet telbija?,Telbiye ne zaman okunur?,\u0645\u062A\u0649
      \u062A\u064F\u0642\u0627\u0644 \u0627\u0644\u062A\u0644\u0628\u064A\u0629\u061F,Kapan
      talbiyah diucapkan?,When is Talbiya pronounced?\r\nQ_L2_OPT_BEFORE_IHRAM,\u0414\u043E
      \u0438\u0445\u0440\u0430\u043C\u0430,Prije ihrama,Para ihramit,\u0130hramdan
      \xF6nce,\u0642\u0628\u0644 \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Sebelum
      ihram,Before ihram\r\nQ_L2_OPT_AFTER_ENTERING_IHRAM,\u041F\u043E\u0441\u043B\u0435
      \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0438\u0445\u0440\u0430\u043C,Nakon
      ulaska u ihram,Pas hyrjes n\xEB ihram,\u0130hrama girdikten sonra,\u0628\u0639\u062F
      \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u0627\u0644\u0625\u062D\u0631\u0627\u0645,Setelah
      memasuki ihram,After entering ihram\r\nQ_L2_OPT_AFTER_ARAFAT,\u041F\u043E\u0441\u043B\u0435
      \u0410\u0440\u0430\u0444\u0430\u0442\u0430,Nakon Arafata,Pas Arafatit,Arafat'tan
      sonra,\u0628\u0639\u062F \u0639\u0631\u0641\u0629,Setelah Arafah,After Arafat\r\nQ_L2_OPT_AFTER_HAJJ,\u041F\u043E\u0441\u043B\u0435
      \u0445\u0430\u0434\u0436\u0430,Nakon had\u017Ea,Pas haxhit,Hacdan sonra,\u0628\u0639\u062F
      \u0627\u0644\u062D\u062C,Setelah haji,After the Hajj\r\nQ_L2_TALBIYAH_EXPLANATION,\u0422\u0430\u043B\u044C\u0431\u0438\u044F
      \u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0441\u043B\u0435
      \u0432\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
      \u0438\u0445\u0440\u0430\u043C\u0430.,Telbija se izgovara nakon ulaska u stanje
      ihrama.,Telbija thuhet pas hyrjes n\xEB gjendjen e ihramit.,Telbiye ihram haline
      girdikten sonra okunur.,\u0627\u0644\u062A\u0644\u0628\u064A\u0629 \u062A\u064F\u0642\u0627\u0644
      \u0628\u0639\u062F \u0627\u0644\u062F\u062E\u0648\u0644 \u0641\u064A \u062D\u0627\u0644\u0629
      \u0627\u0644\u0625\u062D\u0631\u0627\u0645.,Talbiyah diucapkan setelah memasuki
      keadaan ihram.,Talbiya is recited after entering the state of ihram.\r\n,,,,,,,\r\n#
      === LEVEL 3 THEORY ===,,,,,,,\r\nTHEORY_L3_WHAT_IS_TAWAF_TITLE,\u0427\u0442\u043E
      \u0442\u0430\u043A\u043E\u0435 \u0442\u0430\u0432\u0430\u0444,\u0160ta je tavaf,\xC7far\xEB
      \xEBsht\xEB tavafi,Tavaf nedir,\u0645\u0627 \u0647\u0648 \u0627\u0644\u0637\u0648\u0627\u0641,Apa
      itu Tawaf,What is tawaf?\r\nTHEORY_L3_WHAT_IS_TAWAF_TEXT,\u0422\u0430\u0432\u0430\u0444
      \u2014 \u044D\u0442\u043E \u043E\u0431\u0445\u043E\u0434 \u041A\u0430\u0430\u0431\u044B
      \u0441\u0435\u043C\u044C \u0440\u0430\u0437.,Tavaf je obilazak Kabe sedam puta.,Tavafi
      \xEBsht\xEB t\xEB sillesh rreth Qabes shtat\xEB her\xEB.,Tavaf K\xE2be'nin
      yedi kez etraf\u0131nda d\xF6nmektir.,\u0627\u0644\u0637\u0648\u0627\u0641
      \u0647\u0648 \u0627\u0644\u062F\u0648\u0631\u0627\u0646 \u062D\u0648\u0644
      \u0627\u0644\u0643\u0639\u0628\u0629 \u0633\u0628\u0639 \u0645\u0631\u0627\u062A.,Tawaf
      adalah mengelilingi Ka'bah tujuh kali.,Tawaf is walking around the Kaaba seven
      times.\r\nTHEORY_L3_NUMBER_OF_CIRCLES_TITLE,\u041A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
      \u043A\u0440\u0443\u0433\u043E\u0432,Broj krugova,Numri i rrath\xEBve,Devir
      Say\u0131s\u0131,\u0639\u062F\u062F \u0627\u0644\u0623\u0634\u0648\u0627\u0637,Jumlah
      Putaran,Number of laps\r\nTHEORY_L3_NUMBER_OF_CIRCLES_TEXT,\u0412\u043E \u0432\u0440\u0435\u043C\u044F
      \u0442\u0430\u0432\u0430\u0444\u0430 \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0435\u0442\u0441\u044F
      \u0441\u0435\u043C\u044C \u043F\u043E\u043B\u043D\u044B\u0445 \u043A\u0440\u0443\u0433\u043E\u0432.,Tokom
      tavafa se obavi sedam punih krugova.,Gjat\xEB tavafit kryhen shtat\xEB rrath\xEB
      t\xEB plota.,Tavaf s\u0131ras\u0131nda yedi tam devir yap\u0131l\u0131r.,\u064A\u064F\u0624\u062F\u0649
      \u0627\u0644\u0637\u0648\u0627\u0641 \u0628\u0633\u0628\u0639\u0629 \u0623\u0634\u0648\u0627\u0637
      \u0643\u0627\u0645\u0644\u0629.,Selama tawaf dilakukan tujuh putaran penuh.,\"During
      tawaf, seven full circles are performed.\"\r\nTHEORY_L3_START_POINT_TITLE,\u041D\u0430\u0447\u0430\u043B\u043E
      \u043E\u0431\u0445\u043E\u0434\u0430,Po\u010Detak obilaska,Fillimi i silljes,Ba\u015Flang\u0131\xE7
      Noktas\u0131,\u0628\u062F\u0627\u064A\u0629 \u0627\u0644\u0637\u0648\u0627\u0641,Titik
