      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u0443 \u0427\u0451\u0440\u043D\u043E\u0433\u043E
      \u043A\u0430\u043C\u043D\u044F.,Tavaf po\u010Dinje kod Crnog kamena.,Tavafi
      fillon te Guri i Zi.,Tavaf Hacer\xFC'l-Esved'den ba\u015Flar.,\u064A\u0628\u062F\u0623
      \u0627\u0644\u0637\u0648\u0627\u0641 \u0645\u0646 \u0627\u0644\u062D\u062C\u0631
      \u0627\u0644\u0623\u0633\u0648\u062F.,Tawaf dimulai dari Hajar Aswad.,Tawaf
      begins at the Black Stone.\r\nTHEORY_L3_DIRECTION_TITLE,\u041D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435,Smjer,Drejtimi,Y\xF6n,\u0627\u0644\u0627\u062A\u062C\u0627\u0647,Arah,Direction\r\nTHEORY_L3_DIRECTION_TEXT,\u041E\u0431\u0445\u043E\u0434
      \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0435\u0442\u0441\u044F \u043F\u0440\u043E\u0442\u0438\u0432
      \u0447\u0430\u0441\u043E\u0432\u043E\u0439 \u0441\u0442\u0440\u0435\u043B\u043A\u0438.,Obilazak
      se vr\u0161i suprotno od kazaljke na satu.,Sjellja b\xEBhet n\xEB drejtim t\xEB
      kund\xEBrt me akrepat e or\xEBs.,Tavaf saat y\xF6n\xFCn\xFCn tersine yap\u0131l\u0131r.,\u064A\u064F\u0624\u062F\u0649
      \u0627\u0644\u0637\u0648\u0627\u0641 \u0639\u0643\u0633 \u0639\u0642\u0627\u0631\u0628
      \u0627\u0644\u0633\u0627\u0639\u0629.,Tawaf dilakukan berlawanan arah jarum
      jam.,The circumambulation is performed counterclockwise.\r\nTHEORY_L3_RITUAL_PURITY_TITLE,\u0420\u0438\u0442\u0443\u0430\u043B\u044C\u043D\u0430\u044F
      \u0447\u0438\u0441\u0442\u043E\u0442\u0430,Ritualna \u010Disto\u0107a,Past\xEBrtia
      rituale,Abdest,\u0627\u0644\u0637\u0647\u0627\u0631\u0629,Kesucian Ritual,Ritual
      purity\r\nTHEORY_L3_RITUAL_PURITY_TEXT,\u0414\u043B\u044F \u0442\u0430\u0432\u0430\u0444\u0430
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438 \u0432\u0443\u0434\u0443.,Za
      tavaf je potrebno biti u stanju abdesta.,P\xEBr tavafin duhet t\xEB jeni n\xEB
      gjendje t\xEB abdestit.,Tavaf i\xE7in abdestli olmak gerekir.,\u0644\u0644\u0637\u0648\u0627\u0641
      \u064A\u062C\u0628 \u0623\u0646 \u062A\u0643\u0648\u0646 \u0639\u0644\u0649
      \u0648\u0636\u0648\u0621.,Untuk tawaf harus dalam keadaan wudhu.,To perform
      tawaf one must be in a state of wudu.\r\nTHEORY_L3_CIRCLE_COMPLETION_TITLE,\u0417\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435
      \u043A\u0440\u0443\u0433\u0430,Zavr\u0161etak kruga,P\xEBrfundimi i rrathit,Devrin
      Tamamlanmas\u0131,\u0625\u062A\u0645\u0627\u0645 \u0627\u0644\u0634\u0648\u0637,Penyelesaian
      Putaran,Completing the circle\r\nTHEORY_L3_CIRCLE_COMPLETION_TEXT,\u041A\u0440\u0443\u0433
      \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u0437\u0430\u0432\u0435\u0440\u0448\u0451\u043D\u043D\u044B\u043C
      \u043F\u0440\u0438 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
      \u043A \u0427\u0451\u0440\u043D\u043E\u043C\u0443 \u043A\u0430\u043C\u043D\u044E.,Krug
      se smatra zavr\u0161enim pri povratku do Crnog kamena.,Rrethi konsiderohet
      i p\xEBrfunduar kur ktheheni te Guri i Zi.,Devir Hacer\xFC'l-Esved'e d\xF6n\xFCld\xFC\u011F\xFCnde
      tamamlanm\u0131\u015F say\u0131l\u0131r.,\u064A\u064F\u0639\u062A\u0628\u0631
      \u0627\u0644\u0634\u0648\u0637 \u0645\u0643\u062A\u0645\u0644\u0627\u064B \u0639\u0646\u062F
      \u0627\u0644\u0639\u0648\u062F\u0629 \u0625\u0644\u0649 \u0627\u0644\u062D\u062C\u0631
      \u0627\u0644\u0623\u0633\u0648\u062F.,Putaran dianggap selesai saat kembali
      ke Hajar Aswad.,The circle is considered complete upon returning to the Black
      Stone.\r\nTHEORY_L3_DUA_DURING_TAWAF_TITLE,\u0414\u0443\u0430 \u0432\u043E
      \u0432\u0440\u0435\u043C\u044F \u0442\u0430\u0432\u0430\u0444\u0430,Dova tokom
